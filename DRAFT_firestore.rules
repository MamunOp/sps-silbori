rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getProfile().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'role', 'displayName', 'createdAt']) &&
        request.resource.data.role in ['admin', 'parent', 'student'];
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']);
    }

    // Applications
    match /applications/{applicationId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.parentId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.parentId == request.auth.uid);
      allow create: if isEmailVerified() && 
        request.resource.data.parentId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'notes']);
    }

    // Students
    match /students/{studentId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.parentId == request.auth.token.email);
      allow get: if isAdmin() || (isSignedIn() && resource.data.parentId == request.auth.token.email);
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    // Fees (Invoices)
    match /fees/{invoiceId} {
      allow list: if isAdmin() || (isSignedIn()); // List filtered by studentId query
      allow get: if isAdmin() || isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status == 'paid'
      );
    }

    // Payments
    match /payments/{paymentId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
