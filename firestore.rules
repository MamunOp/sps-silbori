rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email == 'mubasiranowar@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'displayName']) &&
               data.uid == userId &&
               data.email is string && 
               data.role in ['admin', 'parent', 'student'] &&
               data.displayName is string &&
               data.displayName.size() <= 100;
      }
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.role == resource.data.role;
    }

    // Admission Applications
    match /applications/{appId} {
      function isValidApp(data) {
        return data.studentName is string && data.studentName.size() <= 100 &&
               data.grade is string &&
               data.parentEmail is string &&
               data.status in ['pending', 'reviewed', 'accepted', 'rejected'];
      }
      allow read: if isAdmin() || (isVerified() && resource.data.parentEmail == request.auth.token.email);
      allow create: if isVerified() && request.resource.data.parentEmail == request.auth.token.email && isValidApp(request.resource.data);
      allow update: if isAdmin() && isValidApp(request.resource.data);
    }

    // Enrolled Students
    match /students/{studentId} {
      function isValidStudent(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.grade is string && 
               data.parentId is string;
      }
      allow read: if isAdmin() || (isVerified() && resource.data.parentId == request.auth.token.email);
      allow write: if isAdmin() && (!request.resource.data.keys().hasAny(['createdAt']) || isValidStudent(request.resource.data));
    }

    // Fee Invoices
    match /fees/{invoiceId} {
      function isStudentParent(studentId) {
        return get(/databases/$(database)/documents/students/$(studentId)).data.parentId == request.auth.token.email;
      }
      allow read: if isAdmin() || (isVerified() && isStudentParent(resource.data.studentId));
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isVerified() && 
        isStudentParent(resource.data.studentId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status == 'paid'
      );
    }

    // Attendance Records
    match /attendance/{recordId} {
      allow read: if isAdmin() || (isVerified() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentId == request.auth.token.email);
      allow write: if isAdmin();
    }
  }
}
